@model IEnumerable<Digital_Products.Models.Category>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Categories</title>
    <link rel="stylesheet" href="~/css/category.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <div class="category-page">
        <header class="category-header">
            <h1>All Categories</h1>

           
                <div class="actions">
                    <a href="/Category/Create" class="add-btn">
                        <i class="fas fa-plus"></i> New Category
                    </a>
                </div>
            



            <div class="search-filter">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Search categories...">
                </div>
            </div>
        </header>


        <main class="categories-grid">
            @foreach (var category in Model)
            {
                <div class="category-card">
                    <div class="category-icon">
                        <img src="@category.ImagePath" asp-append-version="true" alt="@category.Name" />
                        
                    </div>
                    <h3>@category.Name</h3>
                    <p>Category Description</p>
                    <span class="item-count">@category.Products?.Count() ?? 0 Products</span>
                </div>
            }
        </main>
    </div>
</body>
</html>
