@{
}
@model List<Digital_Products.Models.Category>

<h1 class="mb-4">الأقسام</h1>

@if (!Model.Any())
{
    <p>لا توجد أقسام متاحة.</p>
}
else
{
    <div class="row">
        @foreach (var category in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <h5 class="card-title">@category.Name</h5>
                        
                        <a href="/Product/ByCategory/@category.Id" class="btn btn-primary">عرض المنتجات</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
