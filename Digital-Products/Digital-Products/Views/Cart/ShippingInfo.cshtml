@{
}
@model Digital_Products.Models.ShippingInfo
@{
    ViewData["Title"] = "Shipping Information";
    Layout = null; // استبدل بـ Layout الخاص بك إذا لزم الأمر
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shipping Information</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        .shipping-container { max-width: 600px; margin: 0 auto; padding: 20px; }
        .shipping-title { text-align: center; margin-bottom: 20px; }
        .form-group { margin-bottom: 15px; }
        .form-label { font-weight: bold; }
        .btn-submit { background: #ffd814; border: none; padding: 10px 20px; }
    </style>
</head>
<body>
    <div class="shipping-container">
        <h2 class="shipping-title">Shipping Information</h2>
        @if (TempData["Error"] != null)
        {
                <div class="alert alert-danger">@TempData["Error"]</div>
        }
        <form asp-action="ShippingInfo" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Address" class="form-label"></label>
                <input asp-for="Address" class="form-control" required />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="City" class="form-label"></label>
                <input asp-for="City" class="form-control" required />
                <span asp-validation-for="City" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PostalCode" class="form-label"></label>
                <input asp-for="PostalCode" class="form-control" required />
                <span asp-validation-for="PostalCode" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-submit">Complete Checkout</button>
        </form>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script asp-src-include="wwwroot/js/site.js"></script>
</body>
</html>