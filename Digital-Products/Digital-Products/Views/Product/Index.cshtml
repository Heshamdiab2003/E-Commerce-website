@{
    Layout = null; // No layout, standalone HTML
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Products</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Optional: Custom CSS -->
    <style>
        .card-img-top {
            height: 200px;
            object-fit: cover;
        }

        .card {
            transition: transform 0.2s;
        }

            .card:hover {
                transform: scale(1.05);
            }
    </style>
</head>
<body>
    @model IEnumerable<Digital_Products.Models.Product>
    @using Microsoft.AspNetCore.Mvc.Rendering

    <div class="container mt-4">
        <h2 class="mb-4">Products</h2>

        <!-- Search form -->
        <form asp-action="Search" method="get" class="mb-3 d-flex">
            <input type="text" name="query" class="form-control me-2" placeholder="Search products..." />
            <button type="submit" class="btn btn-primary">Search</button>
        </form>

       @*  <!-- Category links -->
        <div class="mb-4">
            <h5>Filter by Category:</h5>
            <div>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-2">All</a>
                <a asp-action="ByCategory" asp-route-id="1" class="btn btn-outline-primary btn-sm me-2">Category 1</a>
                <a asp-action="ByCategory" asp-route-id="2" class="btn btn-outline-primary btn-sm me-2">Category 2</a>
                <a asp-action="ByCategory" asp-route-id="3" class="btn btn-outline-primary btn-sm me-2">Category 3</a>
            </div>
        </div>
 *@
        <!-- Products display -->
        <div class="row">
            @if (!Model.Any())
            {
                <div class="col-12">
                    <div class="alert alert-info">No products found.</div>
                </div>
            }
            else
            {
                @foreach (var product in Model)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card h-100 shadow-sm">
                            <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name">
                            <div class="card-body">
                                <h5 class="card-title">@product.Name</h5>
                                <p class="card-text">@product.Description</p>
                                <p class="card-text"><strong>Price:</strong> $@product.Price</p>
                                <p class="card-text text-muted">Category: @product.Category?.Name</p>
                                <!-- Modified Add to Cart button -->
                                <button class="btn btn-sm btn-success add-to-cart" data-product-id="@product.Id">Add to Cart</button>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Cart Count Display (Optional) -->
        <div class="position-fixed bottom-0 end-0 p-3">
            <span class="badge bg-primary" id="cart-count">0</span> Items in Cart
        </div>
    </div>

    <!-- Anti-forgery token -->
    @Html.AntiForgeryToken()

    <!-- jQuery and Bootstrap JS -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- AJAX Script for Add to Cart -->
    <script>
        $(document).ready(function () {
            $('.add-to-cart').click(function (e) {
                e.preventDefault(); // Prevent default behavior

                var productId = $(this).data('product-id'); // Get product ID

                $.ajax({
                    url: '/Cart/AddToCart',
                    type: 'POST',
                    data: {
                        productId: productId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.success) {
                            alert('Product added to cart successfully!');
                            $('#cart-count').text(response.cartCount); // Update cart count
                        } else {
                            alert('Failed to add product to cart.');
                        }
                    },
                    error: function () {
                        alert('An error occurred while adding to cart.');
                    }
                });
            });
        });
    </script>
</body>
</html>